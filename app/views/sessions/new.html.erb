<div class="mx-auto mt-10 max-w-md">
  <h1 class="text-center text-2xl font-semibold text-gray-900 dark:text-gray-100">Sign in</h1>
  <p class="mt-2 text-center text-sm text-gray-600 dark:text-gray-400">
    <%= link_to "Create an account", new_registrations_path, class: "#{form_back_link_classes} font-normal" %>
  </p>

  <%= form_with url: session_path, class: "mt-6 #{form_card_classes}" do |form| %>
    <div class="space-y-6">
      <div>
        <%= form.label :email, class: form_label_classes %>
        <%= form.email_field :email, required: true, autocomplete: "email", class: form_control_classes %>
      </div>
      <div>
        <%= form.label :password, class: form_label_classes %>
        <%= form.password_field :password, required: true, autocomplete: "current-password", class: form_control_classes %>
      </div>
      <div>
        <%= form.submit "Sign in", class: "#{form_submit_classes} w-full" %>
      </div>
    </div>
  <% end %>
</div>
