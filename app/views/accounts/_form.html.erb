<%= form_with model: @account, class: form_card_classes do |form| %>
  <%= render "application/form_errors", object: @account %>

  <div>
    <%= form.label :name, class: form_label_classes %>
    <%= form.text_field :name, class: form_control_classes, autocomplete: "off" %>
  </div>

  <fieldset class="min-w-0 border-0 p-0">
    <legend class="<%= form_label_classes %> px-0">Account type</legend>
    <div class="mt-3 flex flex-wrap gap-x-6 gap-y-3">
      <% %w[cash person bank].each do |type| %>
        <label class="inline-flex cursor-pointer items-center gap-2">
          <%= form.radio_button :account_type, type, class: form_radio_classes %>
          <span class="<%= form_radio_label_classes %>"><%= type.capitalize %></span>
        </label>
      <% end %>
    </div>
  </fieldset>

  <div>
    <%= form.label :initial_balance, class: form_label_classes %>
    <% initial_locked = @account.persisted? && @account.transactions.exists? %>
    <%= form.number_field :initial_balance,
                          step: :any,
                          class: "#{form_control_classes} tabular-nums",
                          disabled: initial_locked %>
    <% if initial_locked %>
      <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
        Initial balance cannot be changed after this account has transactions. Adjust the balance using transactions instead.
      </p>
    <% else %>
      <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
        For person accounts: use a negative amount if you owe them; positive if they owe you.
      </p>
    <% end %>
  </div>

  <div class="<%= form_secondary_actions_classes %>">
    <%= form.submit class: form_submit_classes %>
  </div>
<% end %>
