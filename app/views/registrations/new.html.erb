<div class="mx-auto mt-10 max-w-md">
  <h1 class="text-center text-2xl font-semibold text-gray-900 dark:text-gray-100">Create account</h1>
  <p class="mt-2 text-center text-sm text-gray-600 dark:text-gray-400">
    Already have an account?
    <%= link_to "Sign in", new_session_path, class: "#{form_back_link_classes} font-normal" %>
  </p>

  <%= form_with model: @user, url: registrations_path, class: "mt-6 #{form_card_classes}" do |form| %>
    <%= render "application/form_errors", object: @user %>
    <div class="space-y-6">
      <div>
        <%= form.label :name, class: form_label_classes %>
        <%= form.text_field :name, autocomplete: "name", class: form_control_classes %>
      </div>
      <div>
        <%= form.label :email, class: form_label_classes %>
        <%= form.email_field :email, autocomplete: "email", class: form_control_classes %>
      </div>
      <div>
        <%= form.label :password, class: form_label_classes %>
        <%= form.password_field :password, autocomplete: "new-password", class: form_control_classes %>
      </div>
      <div>
        <%= form.submit "Create account", class: "#{form_submit_classes} w-full" %>
      </div>
    </div>
  <% end %>
</div>
