<% pairs = dashboard.overview_accounts_with_balances %>
<% total_abs = dashboard_overview_balance_total_abs(pairs) %>
<% top_id = dashboard.highest_balance_account_id %>

<div class="<%= dashboard_card_classes %>">
  <div class="flex items-center justify-between gap-4">
    <h2 class="<%= dashboard_section_heading_classes %>">Accounts</h2>
    <%= link_to "Manage accounts", accounts_path, class: "shrink-0 text-sm font-semibold text-indigo-600 hover:text-indigo-500 dark:text-indigo-400 dark:hover:text-indigo-300", data: { turbo_frame: "_top" } %>
  </div>

  <% if dashboard.no_overview_accounts? %>
    <p class="mt-4 text-sm font-medium text-amber-800 dark:text-amber-200">Add a cash, bank, or person account to track your balances.</p>
    <%= link_to "Add account", new_account_path, class: "mt-4 inline-flex rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 dark:bg-indigo-500 dark:hover:bg-indigo-400", data: { turbo_frame: "_top" } %>
  <% else %>
    <ul class="mt-4 divide-y divide-gray-100 dark:divide-white/10" role="list">
      <% pairs.each do |account, balance| %>
        <li>
          <%= link_to edit_account_path(account), class: "flex items-center justify-between gap-4 py-3 #{'rounded-lg bg-indigo-50/80 px-2 -mx-2 ring-1 ring-indigo-100 dark:bg-indigo-500/10 dark:ring-indigo-500/20' if account.id == top_id}", data: { turbo_frame: "_top" } do %>
            <div class="min-w-0">
              <p class="font-medium text-gray-900 dark:text-white"><%= account.name %></p>
              <% pct = dashboard_account_share_percent(balance, total_abs) %>
              <% if pct.present? %>
                <p class="text-xs text-gray-500 dark:text-gray-400"><%= pct %>% of total (by magnitude)</p>
              <% end %>
            </div>
            <span class="shrink-0 text-sm font-semibold tabular-nums text-gray-900 dark:text-white">
              <%= number_with_delimiter(balance) %>
            </span>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% end %>
</div>
