<div class="sm:flex sm:items-center">
  <div class="sm:flex-auto">
    <h1 class="text-base font-semibold text-gray-900 dark:text-gray-200">Transactions</h1>
  </div>
  <div class="mt-4 sm:mt-0 sm:ml-16 sm:flex-none">
    <%= link_to "Add transaction", new_transaction_path, class: "block rounded-md bg-indigo-600 px-3 py-2 text-center text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 dark:bg-indigo-500 dark:hover:bg-indigo-400 dark:focus-visible:outline-indigo-500" %>
  </div>
</div>

<% if @pagy.count.positive? %>
  <div class="mt-8 flow-root">
    <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8 [scrollbar-gutter:stable]">
      <div class="w-full min-w-0 py-2 align-middle sm:px-6 lg:px-8">
        <div class="overflow-hidden shadow-sm outline-1 outline-black/5 sm:rounded-lg dark:shadow-none dark:-outline-offset-1 dark:outline-white/10">
          <table class="relative w-full table-fixed divide-y divide-gray-300 dark:divide-white/15">
            <colgroup>
              <col class="w-[13%]" />
              <col class="w-[39%]" />
              <col class="w-[14%]" />
              <col class="w-[18%]" />
              <col class="w-[16%]" />
            </colgroup>
            <thead class="bg-gray-50 dark:bg-gray-800/75">
              <tr>
                <th scope="col" class="py-3.5 pr-3 pl-4 text-left text-sm font-semibold text-gray-900 sm:pl-6 dark:text-gray-200">Type</th>
                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-gray-200">Flow</th>
                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-gray-200">Amount</th>
                <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-gray-200">Date</th>
                <th scope="col" class="py-3.5 pr-4 pl-3 text-right text-sm font-semibold text-gray-900 sm:pr-6 dark:text-gray-200">
                  <span class="sr-only">Actions</span>
                </th>
              </tr>
            </thead>
            <tbody id="transactions_tbody" class="divide-y divide-gray-200 bg-white dark:divide-white/10 dark:bg-gray-800/50">
              <%= render partial: "transactions/transaction_row", collection: @transactions, as: :transaction %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <%= render "transactions/pagination" %>
<% else %>
  <p class="mt-8 text-center text-sm text-gray-600 dark:text-gray-400">
    You have no transactions yet.
    <%= link_to "Add your first transaction", new_transaction_path, class: "font-semibold text-indigo-600 hover:text-indigo-500 dark:text-indigo-400 dark:hover:text-indigo-300" %>
    <% if Current.user.accounts.none? %>
      <span class="text-gray-500 dark:text-gray-500"> · </span>
      <%= link_to "Create an account", new_account_path, class: "font-semibold text-indigo-600 hover:text-indigo-500 dark:text-indigo-400 dark:hover:text-indigo-300" %>
    <% end %>
  </p>
<% end %>
