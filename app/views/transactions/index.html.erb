<div class="sm:flex sm:items-center">
    <div class="sm:flex-auto">
      <h1 class="text-base font-semibold text-gray-900 dark:text-gray-200">Transactions</h1>
    </div>
    <div class="mt-4 sm:mt-0 sm:ml-16 sm:flex-none">
      <%= link_to "Add transaction", new_transaction_path, class: "block rounded-md bg-indigo-600 px-3 py-2 text-center text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 dark:bg-indigo-500 dark:hover:bg-indigo-400 dark:focus-visible:outline-indigo-500" %>
    </div>
  </div>

  <% if @transactions.any? %>
    <div class="mt-8 flow-root">
      <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
        <div class="inline-block min-w-full py-2 align-middle sm:px-6 lg:px-8">
          <div class="overflow-hidden shadow-sm outline-1 outline-black/5 sm:rounded-lg dark:shadow-none dark:-outline-offset-1 dark:outline-white/10">
            <table class="relative min-w-full divide-y divide-gray-300 dark:divide-white/15">
              <thead class="bg-gray-50 dark:bg-gray-800/75">
                <tr>
                  <th scope="col" class="py-3.5 pr-3 pl-4 text-left text-sm font-semibold text-gray-900 sm:pl-6 dark:text-gray-200">Type</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-gray-200">Flow</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-gray-200">Amount</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-gray-200">Date</th>
                  <th scope="col" class="py-3.5 pr-4 pl-3 text-right text-sm font-semibold text-gray-900 sm:pr-6 dark:text-gray-200">
                    <span class="sr-only">Actions</span>
                  </th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200 bg-white dark:divide-white/10 dark:bg-gray-800/50">
                <% @transactions.each do |transaction| %>
                  <tr>
                    <td class="py-4 pr-3 pl-4 text-sm whitespace-nowrap sm:pl-6">
                      <span class="<%= transaction_type_badge_classes(transaction.transaction_type) %>">
                        <%= transaction.transaction_type %>
                      </span>
                    </td>
                    <td class="px-3 py-4 text-sm text-gray-900 dark:text-white">
                      <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
                        <span class="font-medium text-gray-900 dark:text-white"><%= transaction.credit_account.name %></span>
                        <span class="inline-flex shrink-0 text-gray-400 dark:text-gray-500" aria-hidden="true">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="size-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                          </svg>
                        </span>
                        <span class="font-medium text-gray-900 dark:text-white"><%= transaction.debit_account.name %></span>
                      </div>
                    </td>
                    <td class="px-3 py-4 text-sm whitespace-nowrap <%= transaction_amount_classes(transaction.transaction_type) %>">
                      <%= number_with_delimiter(transaction.amount) %>
                    </td>
                    <td class="px-3 py-4 text-sm whitespace-nowrap text-gray-500 dark:text-gray-400">
                      <%= l(transaction.transaction_date, format: :long) %>
                    </td>
                    <td class="py-4 pr-4 pl-3 text-right text-sm whitespace-nowrap sm:pr-6" data-turbo-prefetch="false">
                      <%= link_to "Edit", edit_transaction_path(transaction), class: "text-indigo-600 hover:text-indigo-900 dark:text-indigo-400 dark:hover:text-indigo-300" %>
                      <span class="text-gray-300 dark:text-gray-600" aria-hidden="true"> · </span>
                      <%= link_to "Delete", transaction_path(transaction), data: { turbo_method: :delete, turbo_confirm: "Delete this #{transaction.transaction_type} for #{number_with_delimiter(transaction.amount)} on #{l(transaction.transaction_date, format: :long)}?" }, class: "text-red-600 hover:text-red-800 dark:text-red-400 dark:hover:text-red-300" %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <p class="mt-8 text-center text-sm text-gray-600 dark:text-gray-400">
      You have no transactions yet.
      <%= link_to "Add your first transaction", new_transaction_path, class: "font-semibold text-indigo-600 hover:text-indigo-500 dark:text-indigo-400 dark:hover:text-indigo-300" %>
      <% if Current.user.accounts.none? %>
        <span class="text-gray-500 dark:text-gray-500"> · </span>
        <%= link_to "Create an account", new_account_path, class: "font-semibold text-indigo-600 hover:text-indigo-500 dark:text-indigo-400 dark:hover:text-indigo-300" %>
      <% end %>
    </p>
  <% end %>
