<div id="transactions_pagination" class="<%= @pagy.next ? "mt-6 flex w-full justify-center" : "" %>">
  <% if @pagy.next %>
    <div data-controller="load-more" class="flex w-full items-center justify-center">
      <%= link_to transactions_path(request.query_parameters.merge(page: @pagy.next, format: :turbo_stream)),
            class: "inline-flex min-h-11 w-full items-center justify-center gap-2 rounded-md bg-white px-3.5 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 sm:w-auto dark:bg-white/10 dark:text-white dark:ring-white/10 dark:hover:bg-white/15 dark:focus-visible:outline-indigo-500",
            data: {
              turbo: false,
              action: "click->load-more#fetchNext",
            } do %>
        <span data-load-more-target="label">Load more</span>
        <svg data-load-more-target="spinner" class="hidden size-4 animate-spin text-indigo-600 dark:text-indigo-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
      <% end %>
    </div>
  <% end %>
</div>
