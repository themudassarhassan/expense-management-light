<% f = @transactions_filter %>
<% custom_dates = f.date_range == "custom" %>
<div data-controller="transaction-filter-sheet" class="mb-6">
  <button
    type="button"
    class="mb-4 flex w-full min-h-11 items-center justify-center rounded-lg border border-gray-200 bg-white px-4 py-3 text-sm font-semibold text-gray-900 shadow-sm hover:bg-gray-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 sm:hidden dark:border-white/10 dark:bg-white/5 dark:text-white dark:hover:bg-white/10 dark:focus-visible:outline-indigo-500"
    data-transaction-filter-sheet-target="openButton"
    data-action="transaction-filter-sheet#open"
    aria-expanded="false"
    aria-controls="transaction_filters_panel"
  >
    Filters
  </button>

  <div
    id="transaction_filters_panel"
    data-transaction-filter-sheet-target="panel"
    role="region"
    aria-label="Transaction filters"
    class="flex flex-col gap-4 max-sm:hidden sm:flex-row sm:flex-wrap sm:items-end sm:justify-between"
  >
    <div class="flex items-center justify-between border-b border-gray-200 pb-3 sm:hidden dark:border-white/10">
      <span class="text-base font-semibold text-gray-900 dark:text-white">Filters</span>
      <button
        type="button"
        class="inline-flex min-h-11 min-w-11 items-center justify-center rounded-md px-3 text-sm font-semibold text-indigo-600 hover:bg-indigo-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 dark:text-indigo-400 dark:hover:bg-indigo-500/10 dark:focus-visible:outline-indigo-500"
        data-action="transaction-filter-sheet#close"
      >
        Done
      </button>
    </div>

    <div class="flex min-w-0 flex-col gap-4 sm:flex-row sm:items-end sm:gap-6">
      <div class="flex min-w-0 flex-col gap-1">
        <span class="text-xs font-medium text-gray-500 dark:text-gray-400">Date range</span>
        <div
          class="inline-flex max-w-full flex-wrap gap-1 rounded-lg bg-gray-100 p-1 dark:bg-white/5"
          role="group"
          aria-label="Date range"
        >
          <% transaction_date_range_filter_options.each do |label, value| %>
            <%= link_to label, transactions_date_range_filter_path(value), class: transaction_filter_segment_classes(f.date_range == value), data: { turbo_frame: "transactions_index", turbo_action: "advance" } %>
          <% end %>
        </div>
      </div>

      <% if custom_dates %>
        <%= form_with url: transactions_path, method: :get, class: "flex min-w-0 flex-wrap items-end gap-2", data: { turbo_frame: "transactions_index", turbo_action: "advance" } do %>
          <%= hidden_field_tag :date_range, "custom" %>
          <% if f.type.present? %>
            <%= hidden_field_tag :type, f.type %>
          <% end %>
          <div>
            <label for="from_date" class="mb-1 block text-xs font-medium text-gray-500 dark:text-gray-400">From</label>
            <%= date_field_tag :from_date, params[:from_date], id: "from_date", class: form_control_classes, required: true %>
          </div>
          <span class="hidden pb-2 text-sm text-gray-400 sm:inline dark:text-gray-500" aria-hidden="true">→</span>
          <div>
            <label for="to_date" class="mb-1 block text-xs font-medium text-gray-500 dark:text-gray-400">To</label>
            <%= date_field_tag :to_date, params[:to_date], id: "to_date", class: form_control_classes, required: true %>
          </div>
          <%= submit_tag "Apply", class: "inline-flex min-h-11 cursor-pointer items-center justify-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 dark:bg-indigo-500 dark:hover:bg-indigo-400 dark:focus-visible:outline-indigo-500" %>
        <% end %>
      <% end %>

      <div class="flex min-w-0 flex-col gap-1">
        <span class="text-xs font-medium text-gray-500 dark:text-gray-400">Type</span>
        <div class="inline-flex flex-wrap gap-1 rounded-lg bg-gray-100 p-1 dark:bg-white/5" role="group" aria-label="Transaction type">
          <%= link_to "All", transactions_filtered_path(reset_page: true, clear_type: true), class: transaction_filter_segment_classes(f.type.blank?), data: { turbo_frame: "transactions_index", turbo_action: "advance" } %>
          <%= link_to "Income", transactions_filtered_path(type: "income", reset_page: true), class: transaction_filter_segment_classes(f.type == "income"), data: { turbo_frame: "transactions_index", turbo_action: "advance" } %>
          <%= link_to "Expense", transactions_filtered_path(type: "expense", reset_page: true), class: transaction_filter_segment_classes(f.type == "expense"), data: { turbo_frame: "transactions_index", turbo_action: "advance" } %>
          <%= link_to "Transfer", transactions_filtered_path(type: "transfer", reset_page: true), class: transaction_filter_segment_classes(f.type == "transfer"), data: { turbo_frame: "transactions_index", turbo_action: "advance" } %>
        </div>
      </div>
    </div>

    <% if f.resettable? %>
      <div class="shrink-0 sm:ml-auto">
        <%= link_to "Reset filters", transactions_path, class: "inline-flex min-h-11 items-center text-sm font-semibold text-indigo-600 hover:text-indigo-500 dark:text-indigo-400 dark:hover:text-indigo-300", data: { turbo_frame: "transactions_index", turbo_action: "advance" } %>
      </div>
    <% end %>
  </div>
</div>

<% if f.date_range_error.present? %>
  <p class="mb-4 text-sm text-red-600 dark:text-red-400" role="alert"><%= f.date_range_error %></p>
<% end %>
