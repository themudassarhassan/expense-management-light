<% f = @transactions_filter %>
<% if @any_transactions %>
  <% if @pagy.count.positive? %>
    <div class="mt-2 hidden sm:block">
      <div class="flow-root">
        <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8 [scrollbar-gutter:stable]">
          <div class="w-full min-w-0 py-2 align-middle sm:px-6 lg:px-8">
            <div class="overflow-hidden shadow-sm outline-1 outline-black/5 sm:rounded-lg dark:shadow-none dark:-outline-offset-1 dark:outline-white/10">
              <table class="relative w-full table-fixed divide-y divide-gray-300 dark:divide-white/15">
                <colgroup>
                  <col class="w-[13%]" />
                  <col class="w-[39%]" />
                  <col class="w-[14%]" />
                  <col class="w-[18%]" />
                  <col class="w-[16%]" />
                </colgroup>
                <thead class="bg-gray-50 dark:bg-gray-800/75">
                  <tr>
                    <th scope="col" class="py-3.5 pr-3 pl-4 text-left text-sm font-semibold text-gray-900 sm:pl-6 dark:text-gray-200">Type</th>
                    <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-gray-200">Flow</th>
                    <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-gray-200"<% if (asort = transaction_sort_column_aria_sort(f, :amount)) %> aria-sort="<%= asort %>"<% end %>>
                      <%= link_to transactions_sort_header_path(f, :amount), class: transaction_sort_header_link_classes, data: { turbo_frame: "transactions_index", turbo_action: "advance" } do %>
                        <span>Amount</span>
                        <% if transaction_sort_indicator_visible?(f, :amount) %>
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-4 shrink-0 text-indigo-600 dark:text-indigo-400 <%= 'rotate-180' if transaction_sort_indicator_rotate_for_asc?(f, :amount) %>">
                            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                          </svg>
                        <% end %>
                      <% end %>
                    </th>
                    <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-gray-200"<% if (asort = transaction_sort_column_aria_sort(f, :date)) %> aria-sort="<%= asort %>"<% end %>>
                      <%= link_to transactions_sort_header_path(f, :date), class: transaction_sort_header_link_classes, data: { turbo_frame: "transactions_index", turbo_action: "advance" } do %>
                        <span>Date</span>
                        <% if transaction_sort_indicator_visible?(f, :date) %>
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-4 shrink-0 text-indigo-600 dark:text-indigo-400 <%= 'rotate-180' if transaction_sort_indicator_rotate_for_asc?(f, :date) %>">
                            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                          </svg>
                        <% end %>
                      <% end %>
                    </th>
                    <th scope="col" class="py-3.5 pr-4 pl-3 text-right text-sm font-semibold text-gray-900 sm:pr-6 dark:text-gray-200">
                      <span class="sr-only">Actions</span>
                    </th>
                  </tr>
                </thead>
                <tbody id="transactions_tbody" class="divide-y divide-gray-200 bg-white dark:divide-white/10 dark:bg-gray-800/50">
                  <%= render partial: "transactions/transaction_row", collection: @transactions, as: :transaction %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div id="transactions_mobile_list" class="mt-2 block space-y-3 sm:hidden">
      <%= render partial: "transactions/transaction_card", collection: @transactions, as: :transaction %>
    </div>

    <%= render "transactions/pagination" %>
  <% else %>
    <div class="mt-8 rounded-lg border border-dashed border-gray-300 bg-gray-50/80 px-6 py-10 text-center dark:border-white/10 dark:bg-white/5">
      <p class="text-sm font-medium text-gray-900 dark:text-gray-200">No transactions found for selected filters.</p>
      <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Try widening the date range, adjusting account or category filters, or clearing other filters.</p>
      <% if f.resettable? %>
        <div class="mt-6">
          <%= link_to "Reset filters", transactions_path, class: "inline-flex justify-center rounded-md bg-indigo-600 px-3.5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 dark:bg-indigo-500 dark:hover:bg-indigo-400 dark:focus-visible:outline-indigo-500", data: { turbo_frame: "transactions_index", turbo_action: "advance" } %>
        </div>
      <% end %>
    </div>
  <% end %>
<% else %>
  <p class="mt-8 text-center text-sm text-gray-600 dark:text-gray-400">
    You have no transactions yet.
    <%= link_to "Add your first transaction", new_transaction_path, class: "font-semibold text-indigo-600 hover:text-indigo-500 dark:text-indigo-400 dark:hover:text-indigo-300", data: { turbo_frame: "_top" } %>
    <% if Current.user.accounts.none? %>
      <span class="text-gray-500 dark:text-gray-500"> · </span>
      <%= link_to "Create an account", new_account_path, class: "font-semibold text-indigo-600 hover:text-indigo-500 dark:text-indigo-400 dark:hover:text-indigo-300", data: { turbo_frame: "_top" } %>
    <% end %>
  </p>
<% end %>
