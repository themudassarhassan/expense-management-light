<nav class="flex flex-1 flex-col" aria-label="Primary">
  <ul role="list" class="flex flex-1 flex-col gap-y-7">
    <li>
      <p class="px-2 text-xs font-semibold tracking-wide text-gray-500 uppercase">Quick action</p>
      <div class="-mx-2 mt-2">
        <%= link_to new_transaction_path(dashboard_context: 1), class: nav_primary_cta_classes do %>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="size-5 shrink-0">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          New transaction
        <% end %>
      </div>
    </li>
    <li>
      <p class="px-2 text-xs font-semibold tracking-wide text-gray-500 uppercase">Browse</p>
      <ul role="list" class="-mx-2 mt-2 space-y-1">
        <li>
          <%= nav_link_to root_path, match: -> { controller_name == 'home' && action_name == 'index' } do %>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="size-6 shrink-0">
              <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
            </svg>
            Home
          <% end %>
        </li>
        <li>
          <%= nav_link_to transactions_path, match: -> { controller_name == 'transactions' && !%w[new create].include?(action_name) } do %>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="size-6 shrink-0">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
            </svg>
            All transactions
          <% end %>
        </li>
        <li>
          <%= nav_link_to accounts_path do %>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="size-6 shrink-0">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Z" />
            </svg>
            Accounts
          <% end %>
        </li>
        <li>
          <%= nav_link_to budgets_path do %>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" data-slot="icon" aria-hidden="true" class="size-6 shrink-0">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 1 0 7.5 7.5h-7.5V6Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5H21A7.5 7.5 0 0 0 13.5 3v7.5Z" />
            </svg>
            Budgets
          <% end %>
        </li>
      </ul>
    </li>
    <li class="-mx-6 mt-auto">
      <div class="space-y-3 px-6 py-3">
        <div class="flex items-center gap-x-3">
          <span class="flex size-10 shrink-0 items-center justify-center rounded-full bg-white/10 text-sm font-semibold text-white" aria-hidden="true"><%= nav_user_initials %></span>
          <div class="min-w-0 flex-1">
            <p class="truncate text-sm font-semibold text-white"><%= nav_user_display_name %></p>
            <p class="truncate text-xs text-gray-400">Signed in</p>
          </div>
        </div>
        <%= button_to 'Sign out', session_path, method: :delete, class: nav_sign_out_button_classes %>
      </div>
    </li>
  </ul>
</nav>
