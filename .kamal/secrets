# Secrets referenced from config/deploy.yml. Pull from Rails credentials (`credentials:fetch`),
# environment variables your shell exports before `kamal`, or kamal secrets helpers.
# -----------------------------------------------------------------------------
# Observability YAML shape: config/credentials/observability.sample.yml (paste via credentials:edit)
# -----------------------------------------------------------------------------

RAILS_MASTER_KEY=$(cat config/master.key)
KAMAL_REGISTRY_PASSWORD=$(bin/rails credentials:fetch kamal.registry_password)

# Grafana Agent accessory (plaintext env injected by Kamal; values from credentials file)
PROMETHEUS_REMOTE_WRITE_URL=$(bin/rails credentials:fetch grafana_cloud.prometheus_remote_write_url)
LOKI_PUSH_URL=$(bin/rails credentials:fetch grafana_cloud.loki_push_url)
GRAFANA_CLOUD_METRICS_INSTANCE_ID=$(bin/rails credentials:fetch grafana_cloud.metrics_instance_id)
GRAFANA_CLOUD_LOGS_INSTANCE_ID=$(bin/rails credentials:fetch grafana_cloud.logs_instance_id)
GRAFANA_CLOUD_API_KEY=$(bin/rails credentials:fetch grafana_cloud.api_key)

SENTRY_AUTH_TOKEN=$(bin/rails credentials:fetch sentry.auth_token)
SENTRY_ORG_SLUG=$(bin/rails credentials:fetch sentry.org_slug)
SENTRY_PROJECT_SLUG=$(bin/rails credentials:fetch sentry.project_slug)
SENTRY_HOST=$(bin/rails credentials:fetch sentry.host 2>/dev/null || printf '')
